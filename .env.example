# === Mang x402 V2 ===
# "base" = MAINNET (tien that, can CDP key). "base-sepolia" = TESTNET (facilitator free).
X402_NETWORK=base

# Vi nhan USDC tren Base.
PAY_TO=0xcd6b6d99b7751ff30b68fa1365488eb73fa7cefa
RECIPIENT_ADDRESS=0xcd6b6d99b7751ff30b68fa1365488eb73fa7cefa

# CDP key (chi can khi X402_NETWORK=base). Lay o portal.cdp.coinbase.com.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Facilitator testnet (mainnet bo qua).
FACILITATOR_URL=https://x402.org/facilitator

# URL cong khai khi deploy (khong dau / cuoi).
BASE_URL=http://localhost:3000

CONTACT_EMAIL=vanlucpdu@gmail.com

# Gia tung endpoint (USD, KHONG dau $). De trong = dung mac dinh.
# PRICE_PRICE=0.01
# PRICE_TVL=0.01
# PRICE_FEARGREED=0.005

# RPC doc on-chain (cho cac endpoint EVM sau nay). De trong = public.
ETH_RPC_URL=
BASE_RPC_URL=
BNB_RPC_URL=

# Preview key (test bo qua thanh toan). XOA tren production.
PREVIEW_KEY=

# ===== MPP / Tempo (rail thu hai, song song x402) =====
# Vi nhan tien tren Tempo (dia chi EVM dung duoc tren Tempo).
MPP_RECIPIENT=0xYOUR_TEMPO_WALLET
# Token nhan: USDC.e tren Tempo (agent dung duoc). Khong dung USDT0.
PAY_TOKEN=0x20c000000000000000000000b9537d11c60e8b50
TEMPO_NETWORK=mainnet
# URL cong khai khi deploy (KHONG dau / cuoi) - phai khop canonical de realm dung.
BASE_URL=http://localhost:3000
# Secret ky MPP challenge.
MPP_SECRET_KEY=
